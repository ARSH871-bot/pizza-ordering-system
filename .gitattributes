# Normalise line endings to LF in the repository; checkout as CRLF on Windows.
* text=auto eol=crlf

# Force LF for YAML/shell files used by CI (Windows runners handle both)
*.yml  text eol=lf
*.yaml text eol=lf
*.sh   text eol=lf

# Binary files — never touch line endings
*.exe  binary
*.dll  binary
*.pdb  binary
*.png  binary
*.jpg  binary
*.ico  binary
*.zip  binary
