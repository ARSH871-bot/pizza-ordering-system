<?xml version="1.0" encoding="utf-8"?>
<!--
  Explicit package source configuration.
  Prevents accidental package resolution from machine-level NuGet sources
  and ensures reproducible package restores in CI.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
