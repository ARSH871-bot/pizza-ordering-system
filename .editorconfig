root = true

[*.cs]
# ── General formatting ─────────────────────────────────────────────────────
indent_style              = space
indent_size               = 4
end_of_line               = crlf
charset                   = utf-8-bom
trim_trailing_whitespace  = true
insert_final_newline      = true

# ── .NET naming conventions ────────────────────────────────────────────────
dotnet_naming_rule.private_fields_underscore.symbols   = private_fields
dotnet_naming_rule.private_fields_underscore.style     = underscore_prefix
dotnet_naming_rule.private_fields_underscore.severity  = warning

dotnet_naming_symbols.private_fields.applicable_kinds            = field
dotnet_naming_symbols.private_fields.applicable_accessibilities  = private

dotnet_naming_style.underscore_prefix.capitalization  = camel_case
dotnet_naming_style.underscore_prefix.required_prefix = _

# ── Roslyn / FxCop severity overrides ─────────────────────────────────────
# Disable rules that are inappropriate for a WinForms desktop app
dotnet_diagnostic.CA1014.severity = none   # Mark assemblies with CLSCompliant
dotnet_diagnostic.CA1062.severity = none   # Validate arguments (covered by tests)
dotnet_diagnostic.CA1303.severity = none   # Do not pass literals as localised parameters
dotnet_diagnostic.CA1305.severity = none   # Specify IFormatProvider
dotnet_diagnostic.CA1310.severity = none   # Specify StringComparison for correctness
dotnet_diagnostic.CA2007.severity = none   # ConfigureAwait (no async here)
dotnet_diagnostic.CA1034.severity = none   # Nested types should not be visible (OrderLineRecord)

# ── StyleCop: suppress meta-warning that escapes category rules ────────────
dotnet_diagnostic.SA0001.severity = none   # XML comment analysis disabled (no DocumentationFile set)

# ── StyleCop: silence all categories for this WinForms project ─────────────
# Individual SA rules are too noisy for Designer-generated and legacy WinForms
# code. Suppress by category so the build stays warning-free; re-enable
# specific rules below only if they add real value.
dotnet_analyzer_diagnostic.category-StyleCop.CSharp.DocumentationRules.severity  = none
dotnet_analyzer_diagnostic.category-StyleCop.CSharp.LayoutRules.severity          = none
dotnet_analyzer_diagnostic.category-StyleCop.CSharp.MaintainabilityRules.severity = none
dotnet_analyzer_diagnostic.category-StyleCop.CSharp.NamingRules.severity          = none
dotnet_analyzer_diagnostic.category-StyleCop.CSharp.OrderingRules.severity        = none
dotnet_analyzer_diagnostic.category-StyleCop.CSharp.ReadabilityRules.severity     = none
dotnet_analyzer_diagnostic.category-StyleCop.CSharp.SpacingRules.severity         = none
dotnet_analyzer_diagnostic.category-StyleCop.CSharp.SpecialRules.severity         = none

# ── Additional Roslyn suppressions for WinForms-specific patterns ───────────
dotnet_diagnostic.CA1002.severity = none   # Do not expose generic lists (service return types)
dotnet_diagnostic.CA1031.severity = none   # Do not catch general exception (migration swallows errors)
dotnet_diagnostic.CA1051.severity = none   # Do not declare visible instance fields (WinForms controls)
dotnet_diagnostic.CA1501.severity = none   # Avoid excessive inheritance (Form → ContainerControl chain)
dotnet_diagnostic.CA1502.severity = none   # Avoid excessive complexity (large Form1 event handlers)
dotnet_diagnostic.CA1506.severity = none   # Avoid excessive class coupling (Form1 uses many services)
dotnet_diagnostic.CA1711.severity = none   # Identifiers should not have incorrect suffix
dotnet_diagnostic.CA1716.severity = none   # Identifiers should not match keywords
dotnet_diagnostic.CA1724.severity = none   # Type names should not match namespaces
dotnet_diagnostic.CA2213.severity = none   # Disposable fields (WinForms auto-manages control lifetime)
dotnet_diagnostic.CA2227.severity = none   # Collection properties should be read only (OrderRecord.Lines)
dotnet_diagnostic.CA1416.severity = none   # Platform compatibility (entire app is Windows-only net48)
